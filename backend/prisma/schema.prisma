generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Industry {
  AUTO_REPAIR
  DENTAL
  RESTAURANT
  PLUMBING
  HVAC
  LAW_FIRM
  REAL_ESTATE
  MEDICAL
  VETERINARY
  SALON_SPA
  GYM_FITNESS
  ACCOUNTING
  INSURANCE
  ROOFING
  LANDSCAPING
  OTHER
}

enum BusinessState {
  NO_FOUNDATION
  CONVERSION_BROKEN
  LOW_VISIBILITY
  SCALING
  OPTIMIZING
}

enum TriggerType {
  MANUAL
  CRAWLER
}

enum ActionStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTING
  COMPLETED
  FAILED
  SUPERSEDED
}

enum ActionRiskTier {
  LOW
  MEDIUM
  HIGH
}

enum AgentType {
  SEO
  CRO
  REPUTATION
  CONTENT
  MEDIA_BUYER
}

enum AgentCycleStatus {
  TRIGGERED
  PROCESSING
  PARTIAL
  COMPLETE
  TIMEOUT
  FAILED
}

enum ValidationStatus {
  PENDING
  PASSED
  FAILED_SCHEMA
  FAILED_CONFIDENCE
  FAILED_HALLUCINATION
}

enum OutcomeSignal {
  SCORE_IMPROVED
  SCORE_DECLINED
  SCORE_UNCHANGED
  USER_REPORTED_WIN
  USER_REPORTED_LOSS
  NO_SIGNAL
}

enum NotificationChannel {
  EMAIL
  IN_APP
  WEBHOOK
}

enum NotificationEvent {
  AUDIT_COMPLETE
  INBOX_NEW_ACTIONS
  ACTION_EXECUTED
  ACTION_FAILED
  WEEKLY_REPORT_READY
  AGENT_TIMEOUT
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  REMOVED
}

model User {
  id        String   @id
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businesses        Business[]
  memberships       Membership[]
  notificationPrefs NotificationPreference[]
  xpTotal           Int @default(0)

  @@map("users")
}

// ── Membership: join table for multi-user business access ──────────────────
model Membership {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId String
  business   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  role       MembershipRole   @default(MEMBER)
  status     MembershipStatus @default(ACTIVE)
  invitedBy  String?          // userId of the inviter

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, businessId])
  @@index([userId])
  @@index([businessId])
  @@map("memberships")
}

// ── BusinessInvite: pending email invitations ──────────────────────────────
model BusinessInvite {
  id         String         @id @default(cuid())
  businessId String
  business   Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  email      String
  role       MembershipRole @default(MEMBER)
  token      String         @unique @default(cuid())
  invitedBy  String         // userId of the inviter
  acceptedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime       @default(now())

  @@index([businessId])
  @@index([email])
  @@map("business_invites")
}

model Business {
  id     String @id @default(cuid())
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  name     String
  website  String
  industry Industry
  state    BusinessState @default(NO_FOUNDATION)

  crawlerEnrolled    Boolean   @default(false)
  crawlIntervalDays  Int       @default(7)
  nextCrawlAt        DateTime?
  lastCrawlAt        DateTime?
  crawlCooldownUntil DateTime?

  city     String?
  region   String?
  vertical String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditSnapshots AuditSnapshot[]
  agentCycles    AgentCycle[]
  signals        BusinessSignals?
  marketSegment  MarketSegment?
  weeklyActions  WeeklyAction[]
  memberships    Membership[]
  invites        BusinessInvite[]

  @@index([userId])
  @@index([crawlerEnrolled, nextCrawlAt])
  @@index([industry, state])
  @@map("businesses")
}

model AuditSnapshot {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  triggerType TriggerType

  previousSnapshotId String?
  previousSnapshot   AuditSnapshot?  @relation("SnapshotChain", fields: [previousSnapshotId], references: [id])
  nextSnapshots      AuditSnapshot[] @relation("SnapshotChain")

  overallScore       Int
  conversionScore    Int
  seoScore           Int
  reputationScore    Int
  contentScore       Int
  technicalScore     Int
  mobileScore        Int
  trustScore         Int
  localScore         Int
  accessibilityScore Int
  performanceScore   Int

  scoreDelta Json?

  signals   Json
  narrative String
  quickWins Json
  roadmap   Json

  verticalAvgScore Int?
  benchmarkData    Json?

  auditDurationMs Int?
  pageUrl         String
  pageStatusCode  Int?
  sslValid        Boolean @default(false)
  crawlError      String?

  createdAt DateTime @default(now())

  agentCycles   AgentCycle[]
  weeklyActions WeeklyAction[]

  @@index([businessId, createdAt(sort: Desc)])
  @@index([triggerType, createdAt])
  @@map("audit_snapshots")
}

model BusinessSignals {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  hasSSL            Boolean @default(false)
  hasH1             Boolean @default(false)
  hasSchemaMarkup   Boolean @default(false)
  hasSitemap        Boolean @default(false)
  hasRobotsTxt      Boolean @default(false)
  hasBookingWidget  Boolean @default(false)
  hasMobileViewport Boolean @default(false)
  pageLoadMs        Int?
  imageCount        Int?
  imagesWithAlt     Int?
  internalLinkCount Int?
  wordCount         Int?
  cmsDetected       String?

  hasCallToAction   Boolean @default(false)
  hasPricingInfo    Boolean @default(false)
  hasTestimonials   Boolean @default(false)
  hasContactInfo    Boolean @default(false)
  hasBusinessHours  Boolean @default(false)
  hasLocationInfo   Boolean @default(false)
  hasFAQ            Boolean @default(false)
  hasLiveChat       Boolean @default(false)
  hasTrustBadges    Boolean @default(false)
  hasGoogleReviews  Boolean @default(false)
  reviewRating      Float?
  reviewCount       Int?
  ctaClarity        Int?
  contentQuality    Int?
  brandConsistency  Int?

  updatedAt DateTime @updatedAt

  @@map("business_signals")
}

model MarketSegment {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  industry Industry
  region   String?

  avgOverallScore    Float?
  avgConversionScore Float?
  avgSeoScore        Float?
  avgReputationScore Float?
  sampleSize         Int @default(0)

  updatedAt DateTime @updatedAt

  @@index([industry, region])
  @@map("market_segments")
}

model AgentCycle {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  snapshotId String
  snapshot   AuditSnapshot @relation(fields: [snapshotId], references: [id])

  status         AgentCycleStatus @default(TRIGGERED)
  idempotencyKey String           @unique

  triggeredAt DateTime  @default(now())
  timeoutAt   DateTime
  completedAt DateTime?
  durationMs  Int?

  webhookPayload Json

  attemptCount Int @default(1)
  maxAttempts  Int @default(3)
  lastError    String?

  agentExecutions AgentExecution[]
  weeklyActions   WeeklyAction[]

  @@index([businessId, triggeredAt(sort: Desc)])
  @@index([status, timeoutAt])
  @@map("agent_cycles")
}

model AgentExecution {
  id      String     @id @default(cuid())
  cycleId String
  cycle   AgentCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  agentType        AgentType
  status           AgentCycleStatus @default(TRIGGERED)
  validationStatus ValidationStatus @default(PENDING)

  rawOutput        Json?
  validationErrors Json?

  parentExecutionId String?
  parentExecution   AgentExecution?  @relation("ExecutionChain", fields: [parentExecutionId], references: [id])
  childExecutions   AgentExecution[] @relation("ExecutionChain")

  startedAt   DateTime?
  completedAt DateTime?
  durationMs  Int?
  lastError   String?

  weeklyActions WeeklyAction[]

  @@index([cycleId, agentType])
  @@map("agent_executions")
}

model WeeklyAction {
  id          String         @id @default(cuid())
  businessId  String
  business    Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  snapshotId  String
  snapshot    AuditSnapshot  @relation(fields: [snapshotId], references: [id])
  cycleId     String
  cycle       AgentCycle     @relation(fields: [cycleId], references: [id])
  executionId String
  execution   AgentExecution @relation(fields: [executionId], references: [id])

  agentType AgentType
  status    ActionStatus   @default(PENDING)
  riskTier  ActionRiskTier

  title           String
  description     String
  pillar          String
  goal            String
  metric          String
  targetValue     Int?
  baselineValue   Int
  estimatedImpact Int?
  estimatedEffort Int?
  priority        Int @default(50)

  actionType    String
  actionPayload Json

  idempotencyKey String @unique

  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?

  executedAt        DateTime?
  completedAt       DateTime?
  failedAt          DateTime?
  failureReason     String?
  rollbackAvailable Boolean @default(false)
  rollbackPayload   Json?

  outcomeSignal OutcomeSignal @default(NO_SIGNAL)
  outcomeNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outcomeTracking OutcomeTracking?

  @@index([businessId, status, createdAt(sort: Desc)])
  @@index([status, riskTier])
  @@index([pillar, agentType])
  @@map("weekly_actions")
}

model OutcomeTracking {
  id       String       @id @default(cuid())
  actionId String       @unique
  action   WeeklyAction @relation(fields: [actionId], references: [id], onDelete: Cascade)

  scoreBeforeAction Json
  scoreAfterAction  Json?

  targetPillarDelta  Int?
  overallDelta       Int?
  signal             OutcomeSignal @default(NO_SIGNAL)

  followUpSnapshotId String?

  executedAt        DateTime
  outcomeRecordedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("outcome_tracking")
}

model LearningSignal {
  id String @id @default(cuid())

  industry   Industry
  state      BusinessState
  pillar     String
  agentType  AgentType
  actionType String

  sampleSize       Int    @default(0)
  avgTargetDelta   Float?
  avgOverallDelta  Float?
  successRate      Float?
  avgEffortScore   Float?
  confidenceScore  Float?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([industry, state, pillar, agentType, actionType])
  @@index([industry, state, pillar])
  @@map("learning_signals")
}

model WebhookAttemptLog {
  id      String  @id @default(cuid())
  cycleId String?

  url          String
  payload      Json
  statusCode   Int?
  response     Json?
  success      Boolean
  errorMessage String?
  durationMs   Int?

  attemptedAt DateTime @default(now())

  @@index([cycleId])
  @@index([success, attemptedAt(sort: Desc)])
  @@map("webhook_attempt_logs")
}

model NotificationPreference {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  event   NotificationEvent
  channel NotificationChannel
  enabled Boolean @default(true)

  @@unique([userId, event, channel])
  @@map("notification_preferences")
}
